<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" fx:id="root" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.fantasydefender.controller.InfoGameController">
   <children>
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Info Game" VBox.vgrow="ALWAYS" />
            <Separator prefWidth="200.0" />
            <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="30.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="lblLevel" alignment="CENTER" prefWidth="100.0" text="Level" />
                        <Label fx:id="lblPoints" alignment="CENTER" prefWidth="100.0" text="Points" />
                        <Label fx:id="lblCastle" alignment="CENTER" onMouseClicked="#onMouseClickedLblCaastle" prefWidth="100.0" text="Castle" />
                        <Label fx:id="lblCrossbow" alignment="CENTER" onMouseClicked="#onMouseClickedLblCrossbow" prefWidth="100.0" text="Crossbow" />
                        <Label fx:id="lblArrow" alignment="CENTER" onMouseClicked="#onMouseClickedLblArrow" prefWidth="100.0" text="Arrow" />
                        <Label fx:id="lblPower1" alignment="CENTER" onMouseClicked="#onMouseClickedLblPower1" prefWidth="100.0" text="Power1" />
                        <Label fx:id="lblPower2" alignment="CENTER" onMouseClicked="#onMouseClickedLblPower2" prefWidth="100.0" text="Power2" />
                     </children>
                  </VBox>
                  <VBox fx:id="vBoxInfo" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                     <children>
                        <ImageView fx:id="ttack" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                        <Label fx:id="lblInfo1" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Info1" />
                        <Label fx:id="lblInfo2" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Info2" />
                        <Label fx:id="lblInfo3" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Info3" />
                        <Label fx:id="lblInfo4" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Inf4" />
                        <Label fx:id="lblInfo5" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Info5" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
