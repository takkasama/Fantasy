<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="FantasyDefenderPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <class>cr.ac.una.fantasydefender.model.Crossbow</class>
    <class>cr.ac.una.fantasydefender.model.Player</class>
    <class>cr.ac.una.fantasydefender.model.Castle</class>
    <class>cr.ac.una.fantasydefender.model.Game</class>
    <properties>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@//localhost:1521/XEPDB1"/>
      <property name="jakarta.persistence.jdbc.user" value="una"/>
      <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.OracleDriver"/>
      <property name="jakarta.persistence.jdbc.password" value="una"/>
    </properties>
  </persistence-unit>
</persistence>
